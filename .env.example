# Skopiuj do .env i uzupełnij wlasnymi wartosciami.

# Darmowy klucz API Jooble (agregator ofert): https://pl.jooble.org/api/about
# Jesli zostawisz puste, zrodlo Jooble bedzie pominiete.
JOOBLE_API_KEY=

# Limit ofert pobieranych z pojedynczego zrodla
PER_SOURCE_LIMIT=30

# Maksymalna laczna liczba zwracanych wynikow
TOTAL_LIMIT=120

# Timeout pojedynczego zapytania HTTP (sekundy)
REQUEST_TIMEOUT=20

# Aktywne zrodla (po przecinku): jooble,olx,justjoin,nofluffjobs
ENABLED_SOURCES=jooble,olx,justjoin,nofluffjobs

# Serwer (jesli PORT jest zajety, aplikacja sama wybierze nastepny wolny)
HOST=127.0.0.1
PORT=8000
RELOAD=true
